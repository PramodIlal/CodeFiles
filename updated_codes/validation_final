def validate_duplicate_keys(df, primary_key_columns, dataset_name):
    """
    Duplicate detection based on normalized business PK columns.
    Report output shows original/raw PK columns + duplicate count.
    """
    norm_pk_cols = [f"__norm__{pk}" for pk in primary_key_columns]

    grouped_df = (
        df.groupBy(*norm_pk_cols)
          .count()
          .filter(F.col("count") > 1)
    )

    duplicate_count = grouped_df.count()

    if duplicate_count == 0:
        # Empty DF with expected schema
        select_exprs = [F.lit(None).cast("string").alias(pk) for pk in primary_key_columns]
        duplicate_keys_df = df.select(*select_exprs, F.lit(None).cast("long").alias("count")).limit(0)
    else:
        first_raw_df = (
            df.select(*primary_key_columns, *norm_pk_cols)
              .dropDuplicates(norm_pk_cols)
        )

        duplicate_keys_df = (
            grouped_df.alias("g")
            .join(first_raw_df.alias("r"), on=norm_pk_cols, how="left")
            .select(
                *[F.col(f"r.{pk}").alias(pk) for pk in primary_key_columns],
                F.col("g.count").alias("count")
            )
        )

    result = {
        "validation_name": f"{dataset_name.lower()}_duplicate_key_validation",
        "duplicate_key_count": duplicate_count,
        "status": "PASS" if duplicate_count == 0 else "FAIL"
    }

    return result, duplicate_keys_df


def validate_missing_and_extra_by_key(source_df, target_df, primary_key_columns):
    """
    Uses normalized PK columns for matching.
    Reports original/raw PK columns.
    """
    norm_pk_cols = [f"__norm__{pk}" for pk in primary_key_columns]

    source_keys_norm = source_df.select(*primary_key_columns, *norm_pk_cols).dropDuplicates(norm_pk_cols)
    target_keys_norm = target_df.select(*primary_key_columns, *norm_pk_cols).dropDuplicates(norm_pk_cols)

    # source-only
    extra_source_norm = source_keys_norm.alias("s").join(
        target_keys_norm.select(*norm_pk_cols).alias("t"),
        on=norm_pk_cols,
        how="left_anti"
    )

    # target-only
    extra_target_norm = target_keys_norm.alias("t").join(
        source_keys_norm.select(*norm_pk_cols).alias("s"),
        on=norm_pk_cols,
        how="left_anti"
    )

    # matched
    matched_keys_norm = source_keys_norm.select(*norm_pk_cols).alias("s").join(
        target_keys_norm.select(*norm_pk_cols).alias("t"),
        on=norm_pk_cols,
        how="inner"
    ).dropDuplicates(norm_pk_cols)

    extra_source_count = extra_source_norm.count()
    extra_target_count = extra_target_norm.count()
    matched_count = matched_keys_norm.count()

    extra_records_in_source_df = extra_source_norm.select(*primary_key_columns)
    extra_records_in_target_df = extra_target_norm.select(*primary_key_columns)

    result = {
        "validation_name": "missing_extra_by_key_validation",
        "extra_records_in_source_count": extra_source_count,
        "extra_records_in_target_count": extra_target_count,
        "matched_key_count": matched_count,
        "status": "PASS" if extra_source_count == 0 and extra_target_count == 0 else "FAIL"
    }

    return result, extra_records_in_source_df, extra_records_in_target_df, matched_keys_norm


def validate_hash_mismatch(source_df, target_df, primary_key_columns, compare_columns, column_mappings):
    """
    Uses normalized PK and normalized compare columns internally.
    Reports original/raw values only.
    Detailed mismatch output (LONG FORMAT):
      [primary keys..., column_name, source_value, target_value]
    """
    declared_type_map = get_declared_type_map(column_mappings)

    norm_pk_cols = [f"__norm__{pk}" for pk in primary_key_columns]
    norm_compare_cols = [f"__norm__{c}" for c in compare_columns]

    # Add stable row IDs
    source_work = source_df.withColumn("__row_id", F.monotonically_increasing_id())
    target_work = target_df.withColumn("__row_id", F.monotonically_increasing_id())

    # Deduplicate by normalized PK for comparison purpose (keep first row)
    source_dedup = source_work.dropDuplicates(norm_pk_cols)
    target_dedup = target_work.dropDuplicates(norm_pk_cols)

    # Hash only normalized compare columns
    if compare_columns:
        source_hashed = source_dedup.withColumn(
            "__row_hash",
            F.sha2(F.concat_ws("||", *[F.coalesce(F.col(c), F.lit("")) for c in norm_compare_cols]), 256)
        )
        target_hashed = target_dedup.withColumn(
            "__row_hash",
            F.sha2(F.concat_ws("||", *[F.coalesce(F.col(c), F.lit("")) for c in norm_compare_cols]), 256)
        )
    else:
        source_hashed = source_dedup.withColumn("__row_hash", F.lit(None))
        target_hashed = target_dedup.withColumn("__row_hash", F.lit(None))

    # Join matched keys on normalized PK
    joined_df = (
        source_hashed.alias("s")
        .join(
            target_hashed.alias("t"),
            on=norm_pk_cols,
            how="inner"
        )
    )

    # Row-level mismatches
    hash_mismatch_df = joined_df.filter(F.col("s.__row_hash") != F.col("t.__row_hash"))
    mismatch_record_count = hash_mismatch_df.count()

    # Empty result handling
    if mismatch_record_count == 0:
        empty_select = source_df.select(
            *[F.lit(None).cast("string").alias(pk) for pk in primary_key_columns],
            F.lit(None).cast("string").alias("column_name"),
            F.lit(None).cast("string").alias("source_value"),
            F.lit(None).cast("string").alias("target_value")
        ).limit(0)

        result = {
            "validation_name": "hash_mismatch_validation",
            "mismatch_record_count": 0,
            "mismatch_field_count": 0,
            "status": "PASS"
        }
        return result, empty_select

    # Build long-format mismatch rows using RAW values, but compare via normalized internal cols
    mismatch_dfs = []

    for col_name in compare_columns:
        norm_col = f"__norm__{col_name}"

        per_col_mismatch_df = (
            hash_mismatch_df
            .filter(
                F.coalesce(F.col(f"s.{norm_col}"), F.lit("")) !=
                F.coalesce(F.col(f"t.{norm_col}"), F.lit(""))
            )
            .select(
                *[F.col(f"s.{pk}").alias(pk) for pk in primary_key_columns],
                F.lit(col_name).alias("column_name"),
                F.col(f"s.{col_name}").cast("string").alias("source_value"),
                F.col(f"t.{col_name}").cast("string").alias("target_value")
            )
        )

        mismatch_dfs.append(per_col_mismatch_df)

    # Union all mismatch rows
    if mismatch_dfs:
        detailed_mismatch_df = mismatch_dfs[0]
        for df_part in mismatch_dfs[1:]:
            detailed_mismatch_df = detailed_mismatch_df.unionByName(df_part)
        mismatch_field_count = detailed_mismatch_df.count()
    else:
        detailed_mismatch_df = source_df.select(
            *[F.lit(None).cast("string").alias(pk) for pk in primary_key_columns],
            F.lit(None).cast("string").alias("column_name"),
            F.lit(None).cast("string").alias("source_value"),
            F.lit(None).cast("string").alias("target_value")
        ).limit(0)
        mismatch_field_count = 0

    result = {
        "validation_name": "hash_mismatch_validation",
        "mismatch_record_count": mismatch_record_count,
        "mismatch_field_count": mismatch_field_count,
        "status": "PASS" if mismatch_record_count == 0 else "FAIL"
    }

    return result, detailed_mismatch_df


def get_actual_business_type_from_declared(declared_type):
    """
    Since we create __typed__ columns ourselves, schema drift should compare
    these typed internal columns rather than raw DynamoDB physical columns.
    """
    declared_type = (declared_type or "string").lower().strip()

    if declared_type == "numeric":
        return "decimal(38,10)"
    elif declared_type in ["integer", "int", "long", "bigint"]:
        return "bigint"
    elif declared_type in ["float", "double"]:
        return "double"
    elif declared_type == "boolean":
        return "boolean"
    elif declared_type == "date":
        return "date"
    elif declared_type == "timestamp":
        return "timestamp"
    elif declared_type == "string":
        return "string"
    else:
        return "string"


def validate_schema_and_datatype_drift(source_df, target_df, column_mappings):
    """
    IMPORTANT:
    Version 4.0 schema drift compares INTERNAL TYPED COLUMNS (__typed__<col>),
    not raw DynamoDB physical columns.

    This solves the DynamoDB CSV-import issue where non-key columns become string.

    Output columns:
      - column_name
      - declared_data_type
      - source_exists
      - target_exists
      - source_data_type
      - target_data_type
      - drift_type
      - status
    """
    source_schema = get_schema_dict(source_df)
    target_schema = get_schema_dict(target_df)

    drift_rows = []

    for m in column_mappings:
        common_col = m["source_column"]
        declared_type = m.get("data_type", "string").lower().strip()
        typed_col = f"__typed__{common_col}"

        source_exists = typed_col in source_schema
        target_exists = typed_col in target_schema

        source_dtype = source_schema.get(typed_col, None)
        target_dtype = target_schema.get(typed_col, None)

        expected_dtype = get_actual_business_type_from_declared(declared_type)

        if not source_exists:
            drift_type = "MISSING_TYPED_COLUMN_IN_SOURCE"
            status = "FAIL"
        elif not target_exists:
            drift_type = "MISSING_TYPED_COLUMN_IN_TARGET"
            status = "FAIL"
        elif source_dtype != expected_dtype or target_dtype != expected_dtype:
            drift_type = "DECLARED_TYPE_CAST_MISMATCH"
            status = "FAIL"
        elif source_dtype != target_dtype:
            drift_type = "TYPE_MISMATCH_AFTER_CAST"
            status = "FAIL"
        else:
            drift_type = "NO_DRIFT"
            status = "PASS"

        drift_rows.append({
            "column_name": common_col,
            "declared_data_type": declared_type,
            "source_exists": source_exists,
            "target_exists": target_exists,
            "source_data_type": source_dtype,
            "target_data_type": target_dtype,
            "drift_type": drift_type,
            "status": status
        })

    drift_df = pd.DataFrame(drift_rows)

    total_columns_checked = len(column_mappings)
    total_drift_columns = len(drift_df[drift_df["status"] == "FAIL"])
    failed_cast_type_columns = len(drift_df[drift_df["drift_type"] == "DECLARED_TYPE_CAST_MISMATCH"])

    result = {
        "validation_name": "schema_datatype_drift_validation",
        "total_columns_checked": total_columns_checked,
        "total_drift_columns": total_drift_columns,
        "failed_declared_type_cast_columns": failed_cast_type_columns,
        "status": "PASS" if total_drift_columns == 0 else "FAIL"
    }

    return result, drift_df


