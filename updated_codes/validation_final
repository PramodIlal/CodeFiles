def write_csv_from_pandas(df, output_path):
    df.to_csv(output_path, index=False)
    print(f"[OK] CSV written locally: {output_path}")


def write_empty_csv_to_s3(output_s3_uri, columns):
    """
    Writes header-only CSV to S3 for empty output datasets.
    """
    delete_s3_prefix(output_s3_uri)

    bucket, prefix = parse_s3_uri(output_s3_uri)
    if not prefix.endswith("/"):
        prefix += "/"

    header_line = ",".join(columns) + "\n"
    key = prefix + "part-00000-empty.csv"

    s3 = boto3.client("s3")
    s3.put_object(Bucket=bucket, Key=key, Body=header_line.encode("utf-8"))

    # optional _SUCCESS marker
    s3.put_object(Bucket=bucket, Key=prefix + "_SUCCESS", Body=b"")

    print(f"[OK] Empty CSV (header only) written to S3 folder: {output_s3_uri}")


def write_spark_df_as_single_csv(df, output_s3_uri):
    """
    Writes Spark DF directly to S3 as a folder containing a single part file.
    Safe for empty DataFrames.
    """
    row_count = df.count()

    if row_count == 0:
        write_empty_csv_to_s3(output_s3_uri, df.columns)
        return

    delete_s3_prefix(output_s3_uri)

    (
        df.coalesce(1)
          .write
          .mode("overwrite")
          .option("header", "true")
          .csv(output_s3_uri)
    )

    print(f"[OK] Spark CSV written to S3 folder: {output_s3_uri}")


def write_manifest_json(local_tmp_dir, s3_run_output_dir, manifest_dict):
    file_name = "manifest.json"
    local_output_path = os.path.join(local_tmp_dir, file_name)
    s3_output_path = f"{s3_run_output_dir}{file_name}"

    with open(local_output_path, "w", encoding="utf-8") as f:
        json.dump(manifest_dict, f, indent=2)

    upload_file_to_s3(local_output_path, s3_output_path)
    return s3_output_path


def write_detailed_output_files(
    local_tmp_dir,
    s3_run_output_dir,
    schema_drift_detail_df,
    source_cast_report_spark_df,
    target_cast_report_spark_df,
    detailed_mismatch_spark_df,
    extra_records_in_source_spark_df,
    extra_records_in_target_spark_df,
    source_duplicate_keys_spark_df,
    target_duplicate_keys_spark_df
):
    """
    Writes:
    - schema drift (Pandas -> local -> S3)
    - cast failure reports (Spark -> S3)
    - detailed mismatch (Spark -> S3)
    - extra records (Spark -> S3)
    - duplicate keys (Spark -> S3)
    """
    # 1) Schema drift CSV (small)
    schema_drift_local = os.path.join(local_tmp_dir, "schema_datatype_drift.csv")
