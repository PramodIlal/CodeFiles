def is_blank_string(col_expr):
    return F.trim(col_expr.cast("string")) == ""


# ============================================================
# DATA TYPE CASTING (MAPPING-DRIVEN)
# ============================================================
def get_cast_expression(raw_col_name, declared_type):
    """
    Returns Spark expression to cast raw column into declared business type.
    IMPORTANT:
    - Does not overwrite raw/original column.
    - This is for internal typed column creation.
    """
    raw_col = F.col(raw_col_name)

    if declared_type == "numeric":
        # Blank => NULL, else decimal
        return (
            F.when(raw_col.isNull() | is_blank_string(raw_col), F.lit(None))
             .otherwise(F.trim(raw_col.cast("string")).cast("decimal(38,10)"))
        )

    elif declared_type in ["integer", "int", "long", "bigint"]:
        return (
            F.when(raw_col.isNull() | is_blank_string(raw_col), F.lit(None))
             .otherwise(F.trim(raw_col.cast("string")).cast("bigint"))
        )

    elif declared_type in ["float", "double"]:
        return (
            F.when(raw_col.isNull() | is_blank_string(raw_col), F.lit(None))
             .otherwise(F.trim(raw_col.cast("string")).cast("double"))
        )

    elif declared_type == "boolean":
        # Spark boolean cast from strings like true/false works; blank -> null
        return (
            F.when(raw_col.isNull() | is_blank_string(raw_col), F.lit(None))
             .otherwise(F.trim(raw_col.cast("string")).cast("boolean"))
        )

    elif declared_type == "date":
        return (
            F.when(raw_col.isNull() | is_blank_string(raw_col), F.lit(None))
             .otherwise(F.to_date(F.trim(raw_col.cast("string"))))
        )

    elif declared_type == "timestamp":
        return (
            F.when(raw_col.isNull() | is_blank_string(raw_col), F.lit(None))
             .otherwise(F.to_timestamp(F.trim(raw_col.cast("string"))))
        )

    elif declared_type == "string":
        return (
            F.when(raw_col.isNull(), F.lit(None))
             .otherwise(F.trim(raw_col.cast("string")))
        )

    else:
        # fallback to string
        return (
            F.when(raw_col.isNull(), F.lit(None))
             .otherwise(F.trim(raw_col.cast("string")))
        )


def add_typed_internal_columns(df, column_mappings, prefix="__typed__"):
    """
    Adds typed internal columns based on mapping JSON:
      raw column: price
      internal typed column: __typed__price

    Returns:
      transformed_df
    """
    out_df = df

    for m in column_mappings:
        common_col = m["source_column"]
        declared_type = m.get("data_type", "string").lower().strip()

        if common_col not in out_df.columns:
            continue

        typed_col_name = f"{prefix}{common_col}"
        cast_expr = get_cast_expression(common_col, declared_type)
        out_df = out_df.withColumn(typed_col_name, cast_expr)

    return out_df


def generate_cast_failure_report(df, column_mappings, dataset_name, spark):
    """
    Detects cast failures using:
    - raw value is non-null / non-blank
    - typed internal value is null
    => cast failure

    Returns:
      result_dict
      report_df (Spark DF)
    """
    report_rows = []

    for m in column_mappings:
        common_col = m["source_column"]
        declared_type = m.get("data_type", "string").lower().strip()
        typed_col = f"__typed__{common_col}"

        if common_col not in df.columns or typed_col not in df.columns:
            report_rows.append({
                "dataset_name": dataset_name,
                "column_name": common_col,
                "declared_data_type": declared_type,
                "cast_failure_count": 0,
                "status": "SKIPPED"
            })
            continue

        # Only meaningful for non-string typed columns mostly,
        # but we can apply generically.
        failure_df = df.filter(
            F.col(common_col).isNotNull() &
            (~is_blank_string(F.col(common_col))) &
            F.col(typed_col).isNull()
        )

        failure_count = failure_df.count()

        report_rows.append({
            "dataset_name": dataset_name,
            "column_name": common_col,
            "declared_data_type": declared_type,
            "cast_failure_count": failure_count,
            "status": "FAIL" if failure_count > 0 else "PASS"
        })

    report_pdf = pd.DataFrame(report_rows)

    if report_pdf.empty:
        schema = StructType([
            StructField("dataset_name", StringType(), True),
            StructField("column_name", StringType(), True),
            StructField("declared_data_type", StringType(), True),
            StructField("cast_failure_count", LongType(), True),
            StructField("status", StringType(), True),
        ])
        report_df = spark.createDataFrame([], schema)
    else:
        report_df = spark.createDataFrame(report_pdf)

    total_failures = int(report_pdf["cast_failure_count"].sum()) if not report_pdf.empty else 0
    failed_columns = int((report_pdf["cast_failure_count"] > 0).sum()) if not report_pdf.empty else 0

    result = {
        "validation_name": f"{dataset_name.lower()}_cast_failure_validation",
        "failed_columns": failed_columns,
        "total_cast_failures": total_failures,
        "status": "FAIL" if total_failures > 0 else "PASS"
    }

    return result, report_df


