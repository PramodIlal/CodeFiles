def get_normalized_internal_col_expr(common_col, declared_type):
    """
    Returns canonical string representation for internal comparison/join/hash.
    Uses __typed__<col> if present.
    """
    typed_col = F.col(f"__typed__{common_col}")

    if declared_type == "numeric":
        return F.coalesce(typed_col.cast("string"), F.lit(""))

    elif declared_type in ["integer", "int", "long", "bigint"]:
        return F.coalesce(typed_col.cast("string"), F.lit(""))

    elif declared_type in ["float", "double"]:
        return F.coalesce(typed_col.cast("string"), F.lit(""))

    elif declared_type == "boolean":
        return F.coalesce(typed_col.cast("string"), F.lit(""))

    elif declared_type == "date":
        return F.coalesce(F.date_format(typed_col, "yyyy-MM-dd"), F.lit(""))

    elif declared_type == "timestamp":
        return F.coalesce(F.date_format(typed_col, "yyyy-MM-dd HH:mm:ss"), F.lit(""))

    elif declared_type == "string":
        return F.coalesce(typed_col.cast("string"), F.lit(""))

    else:
        return F.coalesce(typed_col.cast("string"), F.lit(""))


def add_normalized_internal_columns(df, column_mappings, prefix="__norm__"):
    """
    Adds normalized internal columns for all mapped columns:
      __norm__cust_id
      __norm__price
      __norm__first_nm
    """
    out_df = df
    declared_type_map = get_declared_type_map(column_mappings)

    for common_col, declared_type in declared_type_map.items():
        if common_col not in out_df.columns:
            continue

        norm_col_name = f"{prefix}{common_col}"
        norm_expr = get_normalized_internal_col_expr(common_col, declared_type)
        out_df = out_df.withColumn(norm_col_name, norm_expr)

    return out_df


